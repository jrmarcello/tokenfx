{
  "name": "tokenfx",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3131",
    "build": "next build",
    "start": "next start -p 3131",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test",
    "ingest": "tsx scripts/ingest.ts",
    "watch": "tsx scripts/watch.ts",
    "seed-dev": "tsx scripts/seed-dev.ts",
    "setup": "pnpm install && pnpm seed-dev",
    "fresh": "rm -f data/dashboard.db data/dashboard.db-wal data/dashboard.db-shm && pnpm ingest",
    "validate": "pnpm typecheck && pnpm lint && pnpm test --run",
    "changelog": "git-cliff --output /dev/stdout",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^4.0.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
